# Frontend API base URL. Keep it relative ("/api") — the Vite dev server proxies
# /api to the local backend, and nginx proxies it in production. A relative value
# prevents a localhost URL from being baked into a production build.
VITE_API_URL=/api
# Backend database connection (server-side only).
DATABASE_URL="mysql://username:password@localhost:3306/stock_management"
JWT_SECRET="your-super-secret-jwt-key-change-this"
PORT=3006
NODE_ENV=development
