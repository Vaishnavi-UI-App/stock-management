generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Organization Master
model Organization {
  id                  String   @id @default(cuid())
  orgName             String
  orgCode             String?  @unique
  businessType        String?
  industry            String?
  logoUrl             String?  @db.Text
  gstNo               String?
  panNo               String?
  tanNo               String?
  cinNo               String?
  email               String?
  phone               String?
  altPhone            String?
  website             String?
  registeredAddress   String?  @db.Text
  factoryAddress      String?  @db.Text
  city                String?
  state               String?
  stateCode           String?
  pincode             String?
  country             String?  @default("India")
  invoicePrefix       String?  @default("INV")
  currency            String?  @default("INR")
  bankName            String?
  bankAccountNo       String?
  bankAccountHolder   String?
  ifscCode            String?
  bankBranch          String?
  upiId               String?
  workingDays         String?
  workingHours        String?
  timezone            String?  @default("Asia/Kolkata")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  status              Boolean  @default(true)

  // Relations
  documents   OrganizationDocument[]
}

// Organization Documents
model OrganizationDocument {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentName   String
  documentType   String?  // gst_certificate, pan_card, trade_license, etc.
  fileData       String   @db.LongText
  fileName       String?
  fileType       String?  // image/png, application/pdf, etc.
  uploadedBy     String?
  createdAt      DateTime @default(now())
}

// User model
model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String
  role             UserRole
  phone            String
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  // Additional employee fields
  profilePhoto     String?  @db.Text
  employeeCode     String?  @unique
  aadharCard       String?
  aadharCardDoc    String?  @db.Text
  panCard          String?
  panCardDoc       String?  @db.Text
  bloodGroup       String?
  emergencyContact String?
  monthlySalary    Float?
  // Bank Details
  bankName          String?
  bankAccountNo     String?
  bankAccountHolder String?
  bankIfscCode      String?
  bankBranchName    String?
  bankPassbookDoc   String?  @db.Text
  // Employment Details
  dateOfJoining    DateTime?
  pfNo             String?    // Provident Fund Number
  esicNo           String?    // ESIC Number
  uanNo            String?    // Universal Account Number
  licenseNo        String?    // License Number
  medicalInsurance String?    // Medical Insurance Number
  designation      String?    // Custom designation text
  location         String?    // Work location
  // Salary Allowances
  basicSalary          Float?
  houseRentAllowance   Float?
  conveyanceAllowance  Float?
  medicalAllowance     Float?
  uniformAllowance     Float?
  educationAllowance   Float?
  ltaAllowance         Float?
  specialAllowance     Float?
  pfDeduction          Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  salesmanStocks SalesmanStock[]
  sales          Sale[]
  stockTransfers StockTransfer[]
  managedBranch  Branch?         @relation("BranchManager")
  orders         Order[]
  expenditures   Expenditure[]
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  damageRecords  DamageRecord[]
  auditLogs      AuditLog[]
  // GPS Tracking relations
  locations      SalesmanLocation[]
  customerVisits CustomerVisit[]
  routeSummaries DailyRouteSummary[]
  // Stock update requests & notifications
  stockRequests  StockUpdateRequest[] @relation("StockRequests")
  notifications  Notification[]       @relation("UserNotifications")
  dealerApplications DealerApplication[]
  // Chat relations
  chatParticipations ConversationParticipant[]
  chatMessages       ChatMessage[]
  chatConversationsCreated Conversation[] @relation("ConversationCreator")
}

enum UserRole {
  stock_manager
  account_manager
  branch_manager
  salesman
}

// Branch model
model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String
  managerId String?  @unique
  manager   User?    @relation("BranchManager", fields: [managerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users          User[]
  branchStocks   BranchStock[]
  salesmanStocks SalesmanStock[]
  sales          Sale[]
  stockTransfers StockTransfer[]
  orders         Order[]
  batches        ProductBatch[]
  damageRecords  DamageRecord[]
  stockUpdateRequests StockUpdateRequest[]
}

// Product model
model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   // HSN Code
  category    String
  price       Float
  mrp         Float?
  unit        String
  caseQty     Int
  gstRate     Float
  description   String?
  expDate       DateTime?     // Product expiry date
  reorderPoint  Int?          // Feature 3: Low stock alert threshold
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  companyStock    CompanyStock?
  branchStocks    BranchStock[]
  salesmanStocks  SalesmanStock[]
  saleItems       SaleItem[]
  stockTransfers  StockTransfer[]
  orderItems      OrderItem[]
  returnItems     SalesReturnItem[]
  batches         ProductBatch[]
  purchaseItems   PurchaseItem[]
  damageRecords   DamageRecord[]
  stockUpdateRequests StockUpdateRequest[]
}

// Company Stock (Main warehouse)
model CompanyStock {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  lastUpdated DateTime @default(now())
}

// Branch Stock
model BranchStock {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  lastUpdated DateTime @default(now())

  @@unique([branchId, productId])
}

// Salesman Stock
model SalesmanStock {
  id         String   @id @default(cuid())
  salesmanId String
  salesman   User     @relation(fields: [salesmanId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  takenDate  DateTime @default(now())

  @@unique([salesmanId, productId])
}

// Stock Transfer
model StockTransfer {
  id            String         @id @default(cuid())
  productId     String
  product       Product        @relation(fields: [productId], references: [id])
  fromBranchId  String?
  fromBranch    Branch?        @relation(fields: [fromBranchId], references: [id])
  toBranchId    String?
  quantity      Int
  transferredBy String
  transferredByUser User       @relation(fields: [transferredBy], references: [id])
  transferDate  DateTime       @default(now())
  status        TransferStatus @default(pending)
}

enum TransferStatus {
  pending
  completed
  cancelled
}

// Customer model for ledger tracking
model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?
  address       String?  @db.Text
  gstin         String?
  pan           String?
  // Balance: positive = customer owes us, negative = we owe customer (advance)
  currentBalance Float   @default(0)
  totalPurchases Float   @default(0)
  totalPaid      Float   @default(0)
  creditLimit    Float?
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  sales        Sale[]
  payments     Payment[]
  transactions CustomerTransaction[]
  returns      SalesReturn[]
  // GPS Tracking relations
  visits       CustomerVisit[]
  location     CustomerLocation?
}

// Payment model to track individual payments
model Payment {
  id            String        @id @default(cuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  saleId        String?
  sale          Sale?         @relation(fields: [saleId], references: [id])
  amount        Float
  paymentMethod PaymentMethod
  referenceNo   String?
  notes         String?
  receivedBy    String
  paymentDate   DateTime      @default(now())
  createdAt     DateTime      @default(now())

  // Relations
  transaction   CustomerTransaction?
}

// Customer Transaction model for ledger entries
model CustomerTransaction {
  id             String          @id @default(cuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  saleId         String?
  sale           Sale?           @relation(fields: [saleId], references: [id])
  paymentId      String?         @unique
  payment        Payment?        @relation(fields: [paymentId], references: [id])
  type           TransactionType
  amount         Float
  balanceAfter   Float
  description    String?
  transactionDate DateTime      @default(now())
  createdAt      DateTime       @default(now())
}

enum TransactionType {
  sale           // Debit - customer owes us (bill amount)
  payment        // Credit - customer paid
  advance        // Credit - advance payment
  refund         // Credit - we refunded
  adjustment     // Can be credit or debit
}

// Sale model
model Sale {
  id              String        @id @default(cuid())
  billNumber      String        @unique
  salesmanId      String
  salesman        User          @relation(fields: [salesmanId], references: [id])
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id])
  // Customer linking (optional for backward compatibility)
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  customerGSTIN   String?
  customerPAN     String?
  totalAmount     Float
  discount        Float         @default(0)
  finalAmount     Float
  // Payment tracking
  amountPaid      Float         @default(0)
  balanceDue      Float         @default(0)
  paymentStatus   PaymentStatus @default(unpaid)
  cgstRate        Float         @default(2.5)
  sgstRate        Float         @default(2.5)
  paymentMethod   PaymentMethod
  status          SaleStatus    @default(pending)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  // Delivery Details
  deliveryNote      String?
  modeOfPayment     String?
  referenceNo       String?
  otherReferences   String?
  buyersOrderNo     String?
  buyersOrderDate   String?
  dispatchDocNo     String?
  deliveryNoteDate  String?
  dispatchedThrough String?
  destination       String?
  poNumber          String?
  vehicleNo         String?
  billLocation      String?       @db.Text
  saleDate        DateTime      @default(now())
  dueDate         DateTime?
  // Soft delete — bills are NEVER hard-deleted, so invoice numbers are never reused
  deletedAt       DateTime?
  deletedBy       String?
  deleteReason    String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  items        SaleItem[]
  payments     Payment[]
  transactions CustomerTransaction[]
  returns      SalesReturn[]
}

enum PaymentStatus {
  paid
  partial
  unpaid
}

enum PaymentMethod {
  cash
  card
  upi
  credit
}

enum SaleStatus {
  pending
  approved
  rejected
}

// Sale Item
model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  price       Float
  total       Float
  hsnCode     String?
  batchNo     String?
  expDate     String?
  mfgDate     String?
  unit        String?
}

// Order model (Purchase Invoice - for salesman to order products)
model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  salesmanId      String
  salesman        User          @relation(fields: [salesmanId], references: [id])
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id])
  // Customer details
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?       @db.Text
  customerGSTIN   String?
  customerPAN     String?
  // Amount details
  totalAmount     Float
  discount        Float         @default(0)
  finalAmount     Float
  // Payment tracking
  amountPaid      Float         @default(0)
  balanceDue      Float         @default(0)
  paymentStatus   PaymentStatus @default(unpaid)
  cgstRate        Float         @default(2.5)
  sgstRate        Float         @default(2.5)
  paymentMethod   PaymentMethod
  // Order status
  orderStatus     OrderStatus   @default(pending)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  convertedSaleId String?       // If approved and converted to sale
  // Delivery Details
  deliveryNote      String?
  modeOfPayment     String?
  referenceNo       String?
  otherReferences   String?
  buyersOrderNo     String?
  buyersOrderDate   String?
  dispatchDocNo     String?
  deliveryNoteDate  String?
  dispatchedThrough String?
  destination       String?
  poNumber          String?
  vehicleNo         String?
  orderLocation     String?       @db.Text
  orderDate       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  items        OrderItem[]
}

enum OrderStatus {
  pending
  approved
  rejected
  converted   // Converted to Tax Invoice/Sale
}

// Order Item
model OrderItem {
  id           String           @id @default(cuid())
  orderId      String
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product          @relation(fields: [productId], references: [id])
  productName  String
  quantity     Int
  price        Float
  total        Float
  hsnCode      String?
  batchNo      String?
  expDate      String?
  mfgDate      String?
  unit         String?
  availability AvailabilityStatus @default(available)
}

enum AvailabilityStatus {
  available
  not_available
}

// Expenditure model for salesman expenses
model Expenditure {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  date          DateTime
  description   String            @db.Text
  amount        Float
  evidenceFile  String?           @db.Text  // Base64 or file path
  evidenceType  String?           // file type: image, pdf, etc.
  evidenceName  String?           // original file name
  status        ExpenditureStatus @default(pending)
  approvedBy    String?
  approvedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum ExpenditureStatus {
  pending
  approved
  rejected
}

// Attendance model
model Attendance {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  date            DateTime         @db.Date
  checkInTime     DateTime?
  checkOutTime    DateTime?
  checkInIp       String?
  checkOutIp      String?
  checkInDevice   String?
  checkOutDevice  String?
  checkInLocation String?
  checkOutLocation String?
  checkInPhoto    String?          @db.LongText
  checkOutPhoto   String?          @db.LongText
  totalHours      Float?
  status          AttendanceStatus @default(present)
  approvalStatus  ApprovalStatus   @default(pending)
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?          @db.Text
  lateReason      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, date])
}

enum AttendanceStatus {
  present
  absent
  half_day
  late
  on_leave
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// ==================== NEW FEATURES ====================

// Feature 2: Sales Return & Credit Notes
model SalesReturn {
  id              String          @id @default(cuid())
  returnNumber    String          @unique
  saleId          String
  sale            Sale            @relation(fields: [saleId], references: [id])
  customerId      String?
  customer        Customer?       @relation(fields: [customerId], references: [id])
  reason          String          @db.Text
  totalAmount     Float
  status          ReturnStatus    @default(pending)
  approvedBy      String?
  approvedAt      DateTime?
  returnDate      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  items           SalesReturnItem[]
}

model SalesReturnItem {
  id              String        @id @default(cuid())
  salesReturnId   String
  salesReturn     SalesReturn   @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  productName     String
  quantity        Int
  price           Float
  total           Float
}

enum ReturnStatus {
  pending
  approved
  rejected
}

// Feature 3: Low Stock Alerts - reorderPoint added to Product
// (reorderPoint field added to Product model via migration)

// Feature 6: Product Expiry Tracking
model ProductBatch {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  batchNo     String
  mfgDate     DateTime?
  expDate     DateTime
  quantity    Int
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([productId, batchNo])
}

// Feature 8: Purchase Management (Vendor/Supplier)
model Supplier {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  phone         String
  email         String?
  gstin         String?
  pan           String?
  address       String?   @db.Text
  bankName      String?
  bankAccountNo String?
  bankIfsc      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  purchases     Purchase[]
}

model Purchase {
  id              String          @id @default(cuid())
  purchaseNumber  String          @unique
  supplierId      String
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  totalAmount     Float
  discount        Float           @default(0)
  finalAmount     Float
  cgstRate        Float           @default(2.5)
  sgstRate        Float           @default(2.5)
  paymentStatus   PaymentStatus   @default(unpaid)
  amountPaid      Float           @default(0)
  balanceDue      Float           @default(0)
  notes           String?         @db.Text
  purchaseDate    DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  items           PurchaseItem[]
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  price       Float
  total       Float
  batchNo     String?
  expDate     String?
  mfgDate     String?
}

// Feature 12: Leave Management
model LeaveRequest {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  leaveType     LeaveType
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  totalDays     Float
  reason        String        @db.Text
  status        ApprovalStatus @default(pending)
  approvedBy    String?
  approvedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum LeaveType {
  casual
  sick
  earned
  unpaid
  maternity
  paternity
}

// Feature 13: Damage/Wastage Tracking
model DamageRecord {
  id            String        @id @default(cuid())
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id])
  quantity      Int
  reason        String        @db.Text
  reportedBy    String
  reportedByUser User         @relation(fields: [reportedBy], references: [id])
  damageDate    DateTime      @default(now())
  status        ApprovalStatus @default(pending)
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
}

// Feature 15: Audit Log
model AuditLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  action      String    // CREATE, UPDATE, DELETE, APPROVE, REJECT, LOGIN, LOGOUT
  entity      String    // Sale, User, Product, etc.
  entityId    String?
  oldValues   String?   @db.Text
  newValues   String?   @db.Text
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

// ==================== GPS TRACKING ====================

// Salesman Location - Real-time GPS tracking
model SalesmanLocation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  latitude    Float
  longitude   Float
  accuracy    Float?    // GPS accuracy in meters
  speed       Float?    // Speed in km/h
  heading     Float?    // Direction in degrees
  altitude    Float?    // Altitude in meters
  batteryLevel Float?   // Device battery percentage
  address     String?   @db.Text  // Reverse geocoded address
  timestamp   DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([userId, timestamp])
}

// Customer Visit - Track visits to customer locations
model CustomerVisit {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerName    String?   // If not linked to customer
  // Check-in details
  checkInTime     DateTime
  checkInLat      Float
  checkInLng      Float
  checkInAddress  String?   @db.Text
  checkInPhoto    String?   @db.LongText  // Selfie/shop photo
  // Check-out details
  checkOutTime    DateTime?
  checkOutLat     Float?
  checkOutLng     Float?
  checkOutAddress String?   @db.Text
  // Visit metrics
  durationMinutes Int?      // Calculated on checkout
  distanceFromCustomer Float? // Distance from customer's registered location
  // Outcome
  visitPurpose    String?   // Sales, Collection, Delivery, Follow-up
  outcome         VisitOutcome?
  notes           String?   @db.Text
  orderId         String?   // If order was created
  saleId          String?   // If sale was made
  amountCollected Float?    // If payment was collected
  visitDate       DateTime  @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, visitDate])
}

enum VisitOutcome {
  order_placed
  payment_collected
  follow_up_needed
  not_interested
  shop_closed
  customer_not_available
  other
}

// Daily Route Summary - Aggregated daily stats
model DailyRouteSummary {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  date              DateTime  @db.Date
  startTime         DateTime?
  endTime           DateTime?
  totalDistanceKm   Float     @default(0)
  totalCustomersPlanned Int   @default(0)
  totalCustomersVisited Int   @default(0)
  totalOrdersTaken  Int       @default(0)
  totalAmountCollected Float  @default(0)
  productiveHours   Float     @default(0)
  idleTimeMinutes   Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, date])
}

// Customer Location - Store customer's registered location for geofencing
model CustomerLocation {
  id          String    @id @default(cuid())
  customerId  String    @unique
  customer    Customer  @relation(fields: [customerId], references: [id])
  latitude    Float
  longitude   Float
  address     String?   @db.Text
  geofenceRadius Float  @default(100) // Radius in meters for visit verification
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== DEALER APPLICATION ====================

enum DealerApplicationStatus {
  pending
  approved
  rejected
}

model DealerApplication {
  id                String                  @id @default(cuid())
  userId            String
  user              User                    @relation(fields: [userId], references: [id])
  // Personal Profile
  firmName          String
  fullAddress       String?                 @db.Text
  firmType          String?
  mobile            String?
  telephone         String?
  email             String?
  // Partners
  partner1Name      String?
  partner1Address   String?                 @db.Text
  partner2Name      String?
  partner2Address   String?                 @db.Text
  partner3Name      String?
  partner3Address   String?                 @db.Text
  residenceAddress  String?                 @db.Text
  // Statutory Details
  pan               String?
  gst               String?
  license           String?
  udyam             String?
  validity          String?
  // Business Details
  businessNature    String?
  turnoverWholesaler String?
  turnoverRetailer  String?
  establishmentDate String?
  // Financial Profile
  bankName          String?
  accountNo         String?
  branch            String?
  ifsc              String?
  // Other Companies
  company1Name      String?
  company1Product   String?
  company1Turnover  String?
  company2Name      String?
  company2Product   String?
  company2Turnover  String?
  company3Name      String?
  company3Product   String?
  company3Turnover  String?
  // Security & Deposit
  chequeNo1         String?
  chequeNo2         String?
  chequeNo3         String?
  bankNameSecurity  String?
  securityAmount    String?
  rtgsDetails       String?
  // Dealer Details
  dealerPlace       String?
  dealerDate        String?
  remark            String?                 @db.Text
  // File uploads (base64)
  photo             String?                 @db.LongText
  stamp             String?                 @db.LongText
  cheque            String?                 @db.LongText
  signature         String?                 @db.LongText
  tsoSignature      String?                 @db.LongText
  // Approval workflow
  status            DealerApplicationStatus @default(pending)
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

// ==================== STOCK UPDATE REQUESTS & NOTIFICATIONS ====================

// Stock Update Request - Branch manager requests stock changes, admin approves
model StockUpdateRequest {
  id                String           @id @default(cuid())
  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id])
  productId         String
  product           Product          @relation(fields: [productId], references: [id])
  requestType       StockRequestType @default(update_quantity)
  currentQuantity   Int?
  requestedQuantity Int
  reason            String?          @db.Text
  requestedBy       String
  requestedByUser   User             @relation("StockRequests", fields: [requestedBy], references: [id])
  status            ApprovalStatus   @default(pending)
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

enum StockRequestType {
  update_quantity
  add_product
}

// Notification - Database-backed notifications for users
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id])
  type        String   // stock_update_request, stock_approved, stock_rejected, etc.
  title       String
  message     String   @db.Text
  entityType  String?  // StockUpdateRequest, etc.
  entityId    String?
  isRead      Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
}

// ==================== CHAT ====================
// Messages are immutable: no edit, no delete. Participants can only send and read.

enum ConversationType {
  direct     // 1-on-1 between exactly two users
  group      // private group with selected participants
  broadcast  // company-wide channel everyone can read (admins/managers post)
}

model Conversation {
  id           String            @id @default(cuid())
  type         ConversationType
  name         String?           // required for group/broadcast; null for direct
  createdById  String
  createdBy    User              @relation("ConversationCreator", fields: [createdById], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  lastMessageAt DateTime?        // bumped when a new message arrives, used to sort list

  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@index([type])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?    // for unread-count calculation

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
